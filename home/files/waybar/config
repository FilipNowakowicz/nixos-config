{
    "layer": "top",
    "position": "top",
    "exclusive": false,
    "height": 48,
    "margin-top": 6,
    "margin-left": 12,
    "margin-right": 12,
    "spacing": 4,

    "modules-left":   ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right":  ["group/tray-group", "custom/anchor"],

    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "active":  "●",
            "default": "●",
            "empty":   "○"
        },
        "persistent-workspaces": {
            "*": 10
        },
        "on-click": "activate",
        "sort-by-number": true
    },

    "clock": {
        "interval": 60,
        "format": "{:%H:%M <span alpha='9999'> · %a %d</span>}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>"
    },

    "group/tray-group": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 300,
            "children-class": "tray-child",
            "transition-left-to-right": false
        },
        "modules": ["custom/chevron", "tray"]
    },

    "custom/chevron": {
        "format": "‹",
        "tooltip": false
    },

    "tray": {
        "icon-size": 14,
        "spacing":   6
    },

    "custom/anchor": {
        "exec":        "waybar-anchor",
        "return-type": "json",
        "interval":    3,
        "on-click":    "control-center",
        "tooltip":     true
    }
}
