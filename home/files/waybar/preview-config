{
    "layer": "top",
    "position": "top",
    "height": 48,
    "margin-top": 6,
    "margin-bottom": 12,
    "margin-left": 12,
    "margin-right": 12,
    "spacing": 4,

    "modules-left":   ["hyprland/workspaces"],
    "modules-center": ["custom/preview-mode", "clock"],
    "modules-right":  ["group/tray-group", "bluetooth", "network", "pulseaudio", "custom/battery-status"],

    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "active":  "â—ڈ",
            "default": "â—ڈ",
            "empty":   "â—‹"
        },
        "persistent-workspaces": {
            "*": 10
        },
        "on-click": "activate",
        "sort-by-number": true
    },

    "custom/preview-mode": {
        "format": "UI PREVIEW",
        "tooltip": false
    },

    "clock": {
        "interval": 60,
        "format": "{:%H:%M <span alpha='9999'> آ· %a %d</span>}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>"
    },

    "group/tray-group": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 300,
            "children-class": "tray-child",
            "transition-left-to-right": false
        },
        "modules": ["custom/chevron", "tray"]
    },

    "custom/chevron": {
        "format": "â€¹",
        "tooltip": false
    },

    "tray": {
        "icon-size": 14,
        "spacing":   6
    },

    "custom/battery-status": {
        "exec":        "battery-status",
        "return-type": "json",
        "interval":    5,
        "on-click":    "power-profile",
        "tooltip":     true
    },

    "pulseaudio": {
        "format":       "َ°•¾",
        "format-muted": "َ°‌ں",
        "format-icons": {
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "on-click":    "nix run path:/home/user/nix#waybar-widget-preview -- audio",
        "scroll-step": 5
    },

    "network": {
        "format-wifi":         "{icon}",
        "format-ethernet":     "َ°ˆ€",
        "format-disconnected": "َ°¤­",
        "format-icons":        ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"],
        "tooltip-format": "{essid} {signalStrength}%",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "nix run path:/home/user/nix#waybar-widget-preview -- wifi"
    },

    "bluetooth": {
        "format":           "َ°‚¯",
        "format-connected": "َ°‚±  {device_alias}",
        "format-off":       "َ°‚²",
        "tooltip-format":   "{controller_alias}\t{controller_address}",
        "on-click":         "nix run path:/home/user/nix#waybar-widget-preview -- bluetooth"
    }
}
