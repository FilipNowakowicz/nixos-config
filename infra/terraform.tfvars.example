# Copy to terraform.tfvars (gitignored) and fill in your values.
# Run `gcloud config get-value project` to find your project ID.

gcp_project = "your-gcp-project-id"

# Optional overrides (defaults are fine for most setups):
# region       = "us-central1"
# zone         = "us-central1-a"
# machine_type = "e2-medium"
# disk_size_gb = 50
# disk_type    = "pd-balanced"  # pd-ssd only if you actually need the IOPS

# Daily GCE boot disk snapshots are provider-local fast rollback, not a restic replacement.
# snapshot_retention_days    = 7
# snapshot_start_time        = "03:00"
# snapshot_storage_locations = ["europe-west2"]
