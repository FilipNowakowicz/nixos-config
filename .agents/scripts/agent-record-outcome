#!/usr/bin/env bash
# Record a compact, machine-readable outcome for one agent issue-run session.
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: agent-record-outcome --issue <n> --status <success|failure|blocked> [options]

Options:
  --base-branch <name>              Base branch used for the run.
  --repo-dir <path>                 Repository directory to inspect (default: cwd).
  --started-at <timestamp>          UTC timestamp captured before the run.
  --finished-at <timestamp>         UTC timestamp captured after the run.
  --exit-code <n>                   Worker exit code (default: 0).
  --blocker <text>                  Failure/blocker summary.
  --learning-candidates-file <path> Newline-separated candidate paths to record.
  --head-branch <name>              Branch to use as a PR discovery fallback.
  --pr-number <n>                   Explicit PR number to record (repeatable).
  --route-file <path>               agent-route --json output to embed under "route".
                                     Ignored if the file's "schema" is not
                                     "agent-route/v1".
  --review-file <path>               Reviewer-evidence JSON to embed under
                                     "review". Ignored if the file's "schema"
                                     is not "agent-reviewer-evidence/v1".
  --session-log <path>              Inner-session log path to record under "session".
  --session-cost-usd <n>            Session cost in USD (from the stream-json result event).
  --session-turns <n>               Session turn count.
  --session-duration-ms <n>         Session duration in milliseconds.
  --session-id <id>                 Inner Claude session id.
  --output-dir <path>               Output directory (default: .agents/state/outcomes).
  --dry-run                         Print JSON instead of writing a file.
  --self-test                       Run a local smoke test and exit.
EOF
}

die() {
  printf 'agent-record-outcome: %s\n' "$*" >&2
  exit 1
}

utc_now() {
  date -u '+%Y-%m-%dT%H:%M:%SZ'
}

json_array_from_lines() {
  jq -Rsc 'split("\n") | map(select(length > 0))'
}

discover_prs() {
  local issue="$1"
  local head_branch="$2"
  local pr_numbers_file="$3"
  if ! command -v gh >/dev/null 2>&1; then
    printf '[]\n'
    return 0
  fi

  local pr_fields
  pr_fields='number,title,state,headRefName,url,reviewDecision,mergeStateStatus'

  {
    if [[ -s $pr_numbers_file ]]; then
      while IFS= read -r pr_number; do
        [[ -n $pr_number ]] || continue
        gh pr view "$pr_number" --json "$pr_fields" 2>/dev/null || true
      done <"$pr_numbers_file"
    fi

    if [[ -n $head_branch && $head_branch != DETACHED ]]; then
      gh pr list --state all --head "$head_branch" --json "$pr_fields" 2>/dev/null || true
    fi

    # The body search alone is too loose: any PR merely quoting "#<issue>"
    # matches. Keep only PRs whose body links the issue with a
    # closing/reference keyword.
    gh pr list --state all --search "#${issue} in:body" --json "${pr_fields},body" 2>/dev/null |
      jq -c --arg issue "$issue" '
        map(select((.body // "")
          | test("(?i)(close[sd]?|fix(es|ed)?|resolve[sd]?|refs?)[[:space:]]+#" + $issue + "\\b")))
        | map(del(.body))' 2>/dev/null || true
  } | jq -cs '
    map(if type == "array" then . else [.] end)
    | (add // [])
    | map(select(type == "object" and (.number | type == "number")))
    | unique_by(.number)
  '
}

collect_learning_candidates() {
  local file="${1:-}"
  if [[ -n $file ]]; then
    [[ -f $file ]] || die "learning-candidates file not found: $file"
    sed '/^[[:space:]]*$/d' "$file" | sort -u
    return 0
  fi

  [[ -d .agents/learning/candidates ]] || return 0
  find .agents/learning/candidates -maxdepth 1 -type f \
    ! -name '.gitkeep' -printf '%p\n' | sort
}

# Build the optional "session" object from the --session-* globals; prints
# "null" when none were provided so the key can be omitted entirely.
build_session_json() {
  if [[ -z $session_log && -z $session_cost_usd && -z $session_turns &&
    -z $session_duration_ms && -z $session_id ]]; then
    printf 'null\n'
    return 0
  fi
  jq -cn \
    --arg log "$session_log" \
    --arg cost "$session_cost_usd" \
    --arg turns "$session_turns" \
    --arg duration_ms "$session_duration_ms" \
    --arg id "$session_id" \
    '{}
     + (if $log == "" then {} else {log: $log} end)
     + (if $cost == "" then {} else {cost_usd: ($cost | tonumber)} end)
     + (if $turns == "" then {} else {turns: ($turns | tonumber)} end)
     + (if $duration_ms == "" then {} else {duration_ms: ($duration_ms | tonumber)} end)
     + (if $id == "" then {} else {id: $id} end)'
}

write_outcome() {
  local issue="$1"
  local status="$2"
  local base_branch="$3"
  local repo_dir="$4"
  local started_at="$5"
  local finished_at="$6"
  local exit_code="$7"
  local blocker="$8"
  local candidates_file="$9"
  local output_dir="${10}"
  local dry_run="${11}"
  local pr_head_branch="${12}"
  local pr_numbers_file="${13}"
  local route_file="${14}"
  local review_file="${15}"

  [[ $issue =~ ^[0-9]+$ ]] || die "--issue must be a positive integer"
  [[ $issue -gt 0 ]] || die "--issue must be a positive integer"
  case "$status" in
  success | failure | blocked) ;;
  *) die "--status must be success, failure, or blocked" ;;
  esac
  [[ $exit_code =~ ^[0-9]+$ ]] || die "--exit-code must be a non-negative integer"

  cd "$repo_dir"

  local resolved_repo head_branch head_sha id safe_finished
  resolved_repo=$(pwd -P)
  head_branch=$(git symbolic-ref --short HEAD 2>/dev/null || printf 'DETACHED')
  head_sha=$(git rev-parse HEAD 2>/dev/null || printf '')
  safe_finished=$(printf '%s' "$finished_at" | tr -c '0-9TZ:-' '-')
  id="${safe_finished}-issue-${issue}-${status}"

  local prs_json candidates_json dirty_json discovery_head_branch route_json review_json
  discovery_head_branch="${pr_head_branch:-$head_branch}"
  prs_json=$(discover_prs "$issue" "$discovery_head_branch" "$pr_numbers_file" | jq -c 'if type == "array" then . else [] end')
  candidates_json=$(collect_learning_candidates "$candidates_file" | json_array_from_lines)
  dirty_json=$(git status --short | json_array_from_lines)

  route_json='null'
  if [[ -n $route_file ]]; then
    [[ -f $route_file ]] || die "route file not found: $route_file"
    route_json=$(jq -c 'if .schema == "agent-route/v1" then . else null end' "$route_file") ||
      die "route file is not valid JSON: $route_file"
  fi

  review_json='null'
  if [[ -n $review_file ]]; then
    [[ -f $review_file ]] || die "review file not found: $review_file"
    review_json=$(jq -c 'if .schema == "agent-reviewer-evidence/v1" then . else null end' "$review_file") ||
      die "review file is not valid JSON: $review_file"
  fi

  # Session telemetry comes from the --session-* globals (not positional
  # parameters) to keep this signature from growing further.
  local session_json
  session_json=$(build_session_json)

  local outcome
  outcome=$(
    jq -cn \
      --arg schema 'agent-outcome/v1' \
      --arg id "$id" \
      --argjson issue "$issue" \
      --arg status "$status" \
      --argjson exit_code "$exit_code" \
      --arg started_at "$started_at" \
      --arg finished_at "$finished_at" \
      --arg base_branch "$base_branch" \
      --arg repo_dir "$resolved_repo" \
      --arg head_branch "$head_branch" \
      --arg head_sha "$head_sha" \
      --argjson prs "$prs_json" \
      --argjson learning_candidates "$candidates_json" \
      --argjson git_dirty "$dirty_json" \
      --arg blocker "$blocker" \
      --argjson route "$route_json" \
      --argjson review "$review_json" \
      --argjson session "$session_json" \
      '{
        schema: $schema,
        id: $id,
        issue: $issue,
        status: $status,
        exit_code: $exit_code,
        started_at: $started_at,
        finished_at: $finished_at,
        base_branch: $base_branch,
        repo_dir: $repo_dir,
        head_branch: $head_branch,
        head_sha: $head_sha,
        prs: $prs,
        learning_candidates: $learning_candidates,
        git_dirty: $git_dirty,
        blocker: $blocker
      } + (if $route == null then {} else {route: $route} end)
        + (if $review == null then {} else {review: $review} end)
        + (if $session == null then {} else {session: $session} end)'
  )

  printf '%s\n' "$outcome" | jq -e \
    '(.schema == "agent-outcome/v1")
     and (.issue > 0)
     and ((.status == "success") or (.status == "failure") or (.status == "blocked"))
     and (.started_at | length > 0)
     and (.finished_at | length > 0)
     and (.prs | type == "array")
     and (.learning_candidates | type == "array")
     and (.git_dirty | type == "array")' >/dev/null

  if [[ $dry_run == 1 ]]; then
    printf '%s\n' "$outcome" | jq -S .
    return 0
  fi

  mkdir -p "$output_dir"
  local path tmp
  path="$output_dir/${id}.json"
  tmp="${path}.tmp"
  printf '%s\n' "$outcome" | jq -S . >"$tmp"
  mv "$tmp" "$path"
  printf '%s\n' "$path"
}

self_test() {
  local tmp repo candidates out bin pr_numbers
  tmp=$(mktemp -d)
  trap 'rm -rf "$tmp"' RETURN
  repo="$tmp/repo"
  out="$tmp/out"
  candidates="$tmp/candidates.txt"
  bin="$tmp/bin"
  pr_numbers="$tmp/pr-numbers.txt"

  mkdir -p "$repo/.agents/learning/candidates" "$bin"
  git -C "$repo" init -q
  git -C "$repo" config user.email test@example.invalid
  git -C "$repo" config user.name 'Agent Outcome Test'
  printf 'seed\n' >"$repo/README.md"
  git -C "$repo" add README.md
  git -C "$repo" commit -q -m seed
  git -C "$repo" checkout -q -b codex/test-outcome-pr
  printf '.agents/learning/candidates/example.yml\n' >"$candidates"
  printf '42\n' >"$pr_numbers"

  cat >"$bin/gh" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

if [[ $1 == pr && $2 == view && $3 == 42 ]]; then
  printf '{"number":42,"title":"test pr","state":"OPEN","headRefName":"codex/test-outcome-pr","url":"https://example.invalid/pr/42","reviewDecision":"","mergeStateStatus":"CLEAN"}\n'
  exit 0
fi

if [[ $1 == pr && $2 == list && $* == *"--head codex/test-outcome-pr"* ]]; then
  printf '[{"number":42,"title":"test pr","state":"OPEN","headRefName":"codex/test-outcome-pr","url":"https://example.invalid/pr/42","reviewDecision":"","mergeStateStatus":"CLEAN"}]\n'
  exit 0
fi

if [[ $1 == pr && $2 == list && $* == *"--search #1 in:body"* ]]; then
  printf '[]\n'
  exit 0
fi

printf 'unexpected gh invocation: %s\n' "$*" >&2
exit 1
EOF
  chmod +x "$bin/gh"

  local json script_path
  script_path="${BASH_SOURCE[0]}"
  json=$(
    PATH="$bin:$PATH" \
      "$script_path" \
      --issue 1 \
      --status success \
      --base-branch main \
      --repo-dir "$repo" \
      --started-at '2026-01-01T00:00:00Z' \
      --finished-at '2026-01-01T00:01:00Z' \
      --exit-code 0 \
      --blocker '' \
      --learning-candidates-file "$candidates" \
      --output-dir "$out" \
      --head-branch 'codex/test-outcome-pr' \
      --pr-number 42 \
      --dry-run
  )

  printf '%s\n' "$json" | jq -e \
    '.schema == "agent-outcome/v1"
     and .issue == 1
     and .status == "success"
     and .blocker == ""
     and (.prs | length == 1)
     and .prs[0].number == 42
     and (.learning_candidates == [".agents/learning/candidates/example.yml"])
     and (has("route") | not)
     and (has("session") | not)' >/dev/null

  # --session-* flags embed a "session" telemetry object.
  json=$(
    PATH="$bin:$PATH" \
      "$script_path" \
      --issue 1 \
      --status success \
      --base-branch main \
      --repo-dir "$repo" \
      --started-at '2026-01-01T00:00:00Z' \
      --finished-at '2026-01-01T00:01:00Z' \
      --exit-code 0 \
      --blocker '' \
      --learning-candidates-file "$candidates" \
      --output-dir "$out" \
      --head-branch 'codex/test-outcome-pr' \
      --pr-number 42 \
      --session-log '.agents/state/sessions/2026-01-01T00:00:00Z-issue-1.log' \
      --session-cost-usd 0.42 \
      --session-turns 7 \
      --session-duration-ms 12345 \
      --session-id 'abc-123' \
      --dry-run
  )
  printf '%s\n' "$json" | jq -e \
    '.session.log == ".agents/state/sessions/2026-01-01T00:00:00Z-issue-1.log"
     and .session.cost_usd == 0.42
     and .session.turns == 7
     and .session.duration_ms == 12345
     and .session.id == "abc-123"' >/dev/null

  # --route-file embeds a valid agent-route/v1 decision under "route".
  local route_file="$tmp/route.json"
  printf '%s\n' '{"schema":"agent-route/v1","paths":["flake.nix"],"path_classes":["nix-modules"],"risk":"medium","default_profile":"nix-engineer","capability_profile":{"id":"nix-engineer","agent":"claude-code","max_risk":"high","escalation":"x"},"required_checks":["bash scripts/validate.sh flake-eval"],"route":"auto","per_path":[]}' >"$route_file"
  json=$(
    PATH="$bin:$PATH" \
      "$script_path" \
      --issue 1 \
      --status success \
      --base-branch main \
      --repo-dir "$repo" \
      --started-at '2026-01-01T00:00:00Z' \
      --finished-at '2026-01-01T00:01:00Z' \
      --exit-code 0 \
      --blocker '' \
      --learning-candidates-file "$candidates" \
      --output-dir "$out" \
      --head-branch 'codex/test-outcome-pr' \
      --pr-number 42 \
      --route-file "$route_file" \
      --dry-run
  )
  printf '%s\n' "$json" | jq -e \
    '.route.schema == "agent-route/v1"
     and .route.risk == "medium"
     and .route.route == "auto"' >/dev/null

  # A route file with the wrong schema is ignored, not embedded.
  local bad_route_file="$tmp/bad-route.json"
  printf '%s\n' '{"schema":"something-else/v1"}' >"$bad_route_file"
  json=$(
    PATH="$bin:$PATH" \
      "$script_path" \
      --issue 1 \
      --status success \
      --base-branch main \
      --repo-dir "$repo" \
      --started-at '2026-01-01T00:00:00Z' \
      --finished-at '2026-01-01T00:01:00Z' \
      --exit-code 0 \
      --blocker '' \
      --learning-candidates-file "$candidates" \
      --output-dir "$out" \
      --head-branch 'codex/test-outcome-pr' \
      --pr-number 42 \
      --route-file "$bad_route_file" \
      --dry-run
  )
  printf '%s\n' "$json" | jq -e '(has("route") | not)' >/dev/null

  # --review-file embeds a valid agent-reviewer-evidence/v1 decision under
  # "review".
  local review_file="$tmp/review.json"
  printf '%s\n' '{"schema":"agent-reviewer-evidence/v1","issue":1,"pr":42,"result":"approved","acceptance_criteria":[{"criterion":"x","evidence":"y"}],"validation_commands":[{"command":"x","result":"passed"}],"residual_risk":"none"}' >"$review_file"
  json=$(
    PATH="$bin:$PATH" \
      "$script_path" \
      --issue 1 \
      --status success \
      --base-branch main \
      --repo-dir "$repo" \
      --started-at '2026-01-01T00:00:00Z' \
      --finished-at '2026-01-01T00:01:00Z' \
      --exit-code 0 \
      --blocker '' \
      --learning-candidates-file "$candidates" \
      --output-dir "$out" \
      --head-branch 'codex/test-outcome-pr' \
      --pr-number 42 \
      --review-file "$review_file" \
      --dry-run
  )
  printf '%s\n' "$json" | jq -e \
    '.review.schema == "agent-reviewer-evidence/v1"
     and .review.result == "approved"' >/dev/null

  # A review file with the wrong schema is ignored, not embedded.
  local bad_review_file="$tmp/bad-review.json"
  printf '%s\n' '{"schema":"something-else/v1"}' >"$bad_review_file"
  json=$(
    PATH="$bin:$PATH" \
      "$script_path" \
      --issue 1 \
      --status success \
      --base-branch main \
      --repo-dir "$repo" \
      --started-at '2026-01-01T00:00:00Z' \
      --finished-at '2026-01-01T00:01:00Z' \
      --exit-code 0 \
      --blocker '' \
      --learning-candidates-file "$candidates" \
      --output-dir "$out" \
      --head-branch 'codex/test-outcome-pr' \
      --pr-number 42 \
      --review-file "$bad_review_file" \
      --dry-run
  )
  printf '%s\n' "$json" | jq -e '(has("review") | not)' >/dev/null

  printf 'agent-record-outcome self-test passed\n'
}

issue=""
status=""
base_branch="${BASE_BRANCH:-main}"
repo_dir="."
started_at=""
finished_at=""
exit_code=0
blocker=""
candidates_file=""
pr_head_branch=""
pr_numbers_file=""
route_file=""
review_file=""
session_log=""
session_cost_usd=""
session_turns=""
session_duration_ms=""
session_id=""
output_dir="${AGENT_OUTCOME_DIR:-.agents/state/outcomes}"
dry_run=0
tmp_pr_numbers=""
trap '[[ -z ${tmp_pr_numbers:-} ]] || rm -f "$tmp_pr_numbers"' EXIT

while [[ $# -gt 0 ]]; do
  case "$1" in
  --issue)
    issue="${2:?--issue needs a value}"
    shift 2
    ;;
  --status)
    status="${2:?--status needs a value}"
    shift 2
    ;;
  --base-branch)
    base_branch="${2:?--base-branch needs a value}"
    shift 2
    ;;
  --repo-dir)
    repo_dir="${2:?--repo-dir needs a value}"
    shift 2
    ;;
  --started-at)
    started_at="${2:?--started-at needs a value}"
    shift 2
    ;;
  --finished-at)
    finished_at="${2:?--finished-at needs a value}"
    shift 2
    ;;
  --exit-code)
    exit_code="${2:?--exit-code needs a value}"
    shift 2
    ;;
  --blocker)
    [[ $# -ge 2 ]] || die "--blocker needs a value"
    blocker="$2"
    shift 2
    ;;
  --learning-candidates-file)
    candidates_file="${2:?--learning-candidates-file needs a value}"
    shift 2
    ;;
  --head-branch)
    pr_head_branch="${2:?--head-branch needs a value}"
    shift 2
    ;;
  --pr-number)
    [[ ${2:?--pr-number needs a value} =~ ^[0-9]+$ ]] || die "--pr-number must be a positive integer"
    tmp_pr_numbers="${tmp_pr_numbers:-$(mktemp)}"
    printf '%s\n' "$2" >>"$tmp_pr_numbers"
    shift 2
    ;;
  --route-file)
    route_file="${2:?--route-file needs a value}"
    shift 2
    ;;
  --review-file)
    review_file="${2:?--review-file needs a value}"
    shift 2
    ;;
  --session-log)
    session_log="${2:?--session-log needs a value}"
    shift 2
    ;;
  --session-cost-usd)
    [[ ${2:?--session-cost-usd needs a value} =~ ^[0-9]+(\.[0-9]+)?$ ]] ||
      die "--session-cost-usd must be a non-negative number"
    session_cost_usd="$2"
    shift 2
    ;;
  --session-turns)
    [[ ${2:?--session-turns needs a value} =~ ^[0-9]+$ ]] ||
      die "--session-turns must be a non-negative integer"
    session_turns="$2"
    shift 2
    ;;
  --session-duration-ms)
    [[ ${2:?--session-duration-ms needs a value} =~ ^[0-9]+$ ]] ||
      die "--session-duration-ms must be a non-negative integer"
    session_duration_ms="$2"
    shift 2
    ;;
  --session-id)
    session_id="${2:?--session-id needs a value}"
    shift 2
    ;;
  --output-dir)
    output_dir="${2:?--output-dir needs a value}"
    shift 2
    ;;
  --dry-run)
    dry_run=1
    shift
    ;;
  --self-test)
    self_test
    exit 0
    ;;
  -h | --help)
    usage
    exit 0
    ;;
  *)
    die "unknown argument: $1"
    ;;
  esac
done

command -v jq >/dev/null 2>&1 || die "jq not found"
command -v git >/dev/null 2>&1 || die "git not found"

[[ -n $issue ]] || die "--issue is required"
[[ -n $status ]] || die "--status is required"
started_at="${started_at:-$(utc_now)}"
finished_at="${finished_at:-$(utc_now)}"

write_outcome "$issue" "$status" "$base_branch" "$repo_dir" "$started_at" \
  "$finished_at" "$exit_code" "$blocker" "$candidates_file" "$output_dir" "$dry_run" \
  "$pr_head_branch" "${tmp_pr_numbers:-/dev/null}" "$route_file" "$review_file"
