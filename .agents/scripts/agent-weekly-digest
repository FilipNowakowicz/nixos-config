#!/usr/bin/env bash
# Read-only weekly digest of agent issue-run outcomes and learning candidates.
#
# Summarizes .agents/state/outcomes (agent-outcome/v1 records, see
# .agents/schemas/outcome.schema.json) and .agents/learning/candidates into a
# short Markdown report: PRs referenced by outcomes, blocked issues, failed
# validations, newly captured learning candidates, run durations, and a
# "human decisions needed" list. Read-only; files no comments or issues.
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: agent-weekly-digest [--dir <path>] [--since <date>] [--candidates-dir <path>]
       agent-weekly-digest --self-test

Reads agent-outcome/v1 records from --dir (default: .agents/state/outcomes,
or $AGENT_OUTCOME_DIR) using the same schema assumptions as
.agents/scripts/agent-outcome-index, and learning-candidate files from
--candidates-dir (default: .agents/learning/candidates), and prints a
Markdown digest covering:

  - PRs referenced by outcomes (number, state, title, url)
  - blocked issues with their recorded blocker reasons
  - failed runs (status=failure) with exit code and blocker
  - learning candidates captured by in-window runs
  - run durations (finished_at - started_at)
  - a "human decisions needed" rollup (open PRs, blocked issues, failures)
  - a reserved cost/token section (only populated if outcome records ever
    carry those fields; never fabricated)

Options:
  --dir <path>            Outcome directory to scan (default:
                           .agents/state/outcomes, or $AGENT_OUTCOME_DIR).
  --since <date>          Only include records with started_at >= <date>
                           (ISO 8601, e.g. 2026-06-01 or
                           2026-06-01T00:00:00Z). Default: no lower bound.
  --candidates-dir <path> Learning-candidate directory to scan (default:
                           .agents/learning/candidates).
  --self-test             Run a deterministic self-test against local
                           fixtures (no GitHub or model calls) and exit.
  -h, --help              Show this help.

This digest is read-only: it does not file issues, post comments, merge PRs,
or compute cost/token totals beyond fields already present in outcome
records.
EOF
}

die() {
  printf 'agent-weekly-digest: %s\n' "$*" >&2
  exit 1
}

# Read valid agent-outcome/v1 records from $1, optionally filtered to
# started_at >= $2 (empty = no filter), and emit one compact JSON object per
# line. Mirrors agent-outcome-index's validity check (same schema
# assumptions), but keeps the full record so PR state/title and
# learning_candidates remain available.
read_records() {
  local dir="$1" since="$2" file json
  [[ -d $dir ]] || return 0
  while IFS= read -r -d '' file; do
    json=$(jq -c . "$file" 2>/dev/null) || continue
    printf '%s\n' "$json" | jq -e '
      (.schema == "agent-outcome/v1")
      and (.issue | type == "number" and . > 0)
      and ((.status == "success") or (.status == "failure") or (.status == "blocked"))
      and (.started_at | type == "string")
      and (.finished_at | type == "string")
      and (.prs | type == "array")
      and (.blocker | type == "string")
    ' >/dev/null 2>&1 || continue
    if [[ -n $since ]]; then
      printf '%s\n' "$json" | jq -e --arg since "$since" '.started_at >= $since' >/dev/null 2>&1 || continue
    fi
    printf '%s\n' "$json"
  done < <(find "$dir" -maxdepth 1 -type f -name '*.json' -print0 | sort -z)
}

list_candidates() {
  local dir="$1"
  [[ -d $dir ]] || return 0
  find "$dir" -maxdepth 1 -type f -name '*.yml' ! -name '.gitkeep' -printf '%f\n' | sort
}

candidate_field() {
  local path="$1"
  local name="$2"
  sed -n "s/^${name}:[[:space:]]*//p" "$path" | head -1 |
    tr '\t' ' ' |
    sed "s/^\"//; s/\"$//; s/^'//; s/'$//"
}

top_recurring_open_candidates() {
  local dir="$1"
  [[ -d $dir ]] || return 0

  local rows counts
  rows=$(mktemp)
  counts=$(mktemp)

  while IFS= read -r -d '' path; do
    local status dedupe id
    status=$(candidate_field "$path" status)
    [[ $status == open ]] || continue
    dedupe=$(candidate_field "$path" dedupe_key)
    [[ -n $dedupe ]] || continue
    id=$(candidate_field "$path" id)
    [[ -n $id ]] || id=$(basename "$path")
    printf '%s\t%s\t%s\n' "$dedupe" "$id" "$(basename "$path")" >>"$rows"
    printf '%s\n' "$dedupe" >>"$counts"
  done < <(find "$dir" -maxdepth 1 -type f -name '*.yml' ! -name '.gitkeep' -print0 | sort -z)

  if [[ ! -s $rows ]]; then
    rm -f "$rows" "$counts"
    return 0
  fi

  sort "$counts" |
    uniq -c |
    awk '$1 > 1 { count=$1; $1=""; sub(/^ /, ""); print count "\t" $0 }' |
    sort -t "$(printf '\t')" -k1,1rn -k2,2 |
    awk -F '\t' -v rows="$rows" '
      NR <= 10 {
        dedupe = $2
        first_id = ""
        first_file = ""
        while ((getline row < rows) > 0) {
          split(row, fields, "\t")
          if (fields[1] == dedupe && first_id == "") {
            first_id = fields[2]
            first_file = fields[3]
          }
        }
        close(rows)
        print "- captured " $1 " times: " dedupe " (" first_id ", " first_file ")"
      }'
  rm -f "$rows" "$counts"
}

# Reviewer-vs-CI/merge calibration: for outcome records carrying a "review"
# field (agent-reviewer-evidence/v1, embedded via agent-record-outcome
# --review-file), flag two kinds of miscalibration against the linked PRs'
# eventual GitHub state:
#   - reviewer said "approved" but a linked PR was closed without merging, or
#     is not cleanly mergeable/CI-green (mergeStateStatus DIRTY/BLOCKED/UNSTABLE)
#   - reviewer said "changes_requested"/"blocked" but a linked PR merged anyway
reviewer_ci_calibration() {
  local records_file="$1"
  local approved_but_not_clean flagged_but_merged

  approved_but_not_clean=$(jq -rs '
    [.[] | select((.review.result? // "") == "approved")]
    | sort_by(.issue)
    | .[] | .issue as $issue
      | .prs[]?
      | select((.state == "CLOSED") or ((.mergeStateStatus // "") | IN("DIRTY", "BLOCKED", "UNSTABLE")))
      | "- #\($issue): PR #\(.number) approved by reviewer but state=\(.state), mergeStateStatus=\(.mergeStateStatus // "n/a")"
  ' "$records_file")

  flagged_but_merged=$(jq -rs '
    [.[] | select((.review.result? // "") | IN("changes_requested", "blocked"))]
    | sort_by(.issue)
    | .[] | .issue as $issue | .review.result as $result
      | .prs[]?
      | select(.state == "MERGED")
      | "- #\($issue): PR #\(.number) merged despite reviewer result=\($result)"
  ' "$records_file")

  echo "### Approved by reviewer but PR closed unmerged or not CI-clean"
  echo
  if [[ -n $approved_but_not_clean ]]; then
    printf '%s\n' "$approved_but_not_clean"
  else
    echo "- (none)"
  fi
  echo
  echo "### Reviewer requested changes or blocked but PR merged anyway"
  echo
  if [[ -n $flagged_but_merged ]]; then
    printf '%s\n' "$flagged_but_merged"
  else
    echo "- (none)"
  fi
}

render_digest() {
  local records_file="$1"
  local candidates_dir="$2"
  local since="$3"
  local count
  count=$(wc -l <"$records_file" | tr -d ' ')

  echo "# Agent Weekly Digest"
  echo
  if [[ -n $since ]]; then
    echo "Window: started_at >= ${since} (${count} outcome record(s))"
  else
    echo "Window: all recorded outcomes (${count} outcome record(s))"
  fi
  echo

  echo "## PRs referenced by outcomes"
  echo
  if [[ $count -gt 0 ]] && jq -se '[.[] | .prs[]] | length > 0' "$records_file" >/dev/null 2>&1 &&
    [[ $(jq -se '[.[] | .prs[]] | length' "$records_file") -gt 0 ]]; then
    jq -rs '
      [.[] | .prs[] | {number, state, title, url}]
      | unique_by(.number)
      | sort_by(.number)
      | .[] | "- #\(.number) \(.state) — \(.title) (\(.url))"
    ' "$records_file"
  else
    echo "- (none)"
  fi
  echo

  echo "## Blocked issues"
  echo
  if jq -se '[.[] | select(.status == "blocked")] | length > 0' "$records_file" >/dev/null 2>&1; then
    jq -rs '
      [.[] | select(.status == "blocked")]
      | sort_by(.issue)
      | .[] | "- #\(.issue): \(.blocker)"
    ' "$records_file"
  else
    echo "- (none)"
  fi
  echo

  echo "## Failed validations"
  echo
  if jq -se '[.[] | select(.status == "failure")] | length > 0' "$records_file" >/dev/null 2>&1; then
    jq -rs '
      [.[] | select(.status == "failure")]
      | sort_by(.issue)
      | .[] | "- #\(.issue) (exit \(.exit_code // "?")): \(.blocker)"
    ' "$records_file"
  else
    echo "- (none)"
  fi
  echo

  echo "## Learning candidates captured this window"
  echo
  if jq -se '[.[] | .learning_candidates[]?] | length > 0' "$records_file" >/dev/null 2>&1; then
    jq -rs '
      [.[] | .issue as $issue | .learning_candidates[]? | {path: ., issue: $issue}]
      | group_by(.path)
      | map({path: .[0].path, issues: (map(.issue) | unique)})
      | sort_by(.path)
      | .[] | "- \(.path) (issue(s): \(.issues | map("#" + (tostring)) | join(", ")))"
    ' "$records_file"
  else
    echo "- (none)"
  fi
  echo

  echo "## Currently open learning candidates"
  echo
  local cand
  local found=0
  while IFS= read -r cand; do
    [[ -n $cand ]] || continue
    found=1
    echo "- ${cand}"
  done < <(list_candidates "$candidates_dir")
  [[ $found == 1 ]] || echo "- (none)"
  echo

  echo "## Top recurring open learning candidates"
  local recurring
  recurring=$(top_recurring_open_candidates "$candidates_dir")
  if [[ -n $recurring ]]; then
    printf '%s\n' "$recurring"
  else
    echo "- (none)"
  fi
  echo

  echo "## Reviewer vs CI/merge calibration"
  echo
  reviewer_ci_calibration "$records_file"
  echo

  echo "## Run durations"
  echo
  echo "| issue | status | duration |"
  echo "| --- | --- | --- |"
  if [[ $count -gt 0 ]]; then
    jq -rs '
      sort_by(.issue)
      | .[] | (
          ((.finished_at | fromdateiso8601) - (.started_at | fromdateiso8601)) as $secs
          | "| #\(.issue) | \(.status) | \($secs)s |"
        )
    ' "$records_file"
  else
    echo "| (none) | | |"
  fi
  echo

  echo "## Human decisions needed"
  echo
  local any=0
  if jq -se '[.[] | .prs[] | select(.state == "OPEN")] | length > 0' "$records_file" >/dev/null 2>&1; then
    any=1
    jq -rs '
      [.[] | .prs[] | select(.state == "OPEN")]
      | unique_by(.number)
      | sort_by(.number)
      | .[] | "- PR #\(.number) is OPEN and awaiting review/merge: \(.title) (\(.url))"
    ' "$records_file"
  fi
  if jq -se '[.[] | select(.status == "blocked")] | length > 0' "$records_file" >/dev/null 2>&1; then
    any=1
    jq -rs '
      [.[] | select(.status == "blocked")]
      | sort_by(.issue)
      | .[] | "- Issue #\(.issue) is blocked: \(.blocker)"
    ' "$records_file"
  fi
  if jq -se '[.[] | select(.status == "failure")] | length > 0' "$records_file" >/dev/null 2>&1; then
    any=1
    jq -rs '
      [.[] | select(.status == "failure")]
      | sort_by(.issue)
      | .[] | "- Issue #\(.issue) run failed and needs investigation: \(.blocker)"
    ' "$records_file"
  fi
  [[ $any == 1 ]] || echo "- (none)"
  echo

  echo "## Cost / token usage"
  echo
  if jq -se '[.[] | select(has("cost") or has("tokens"))] | length > 0' "$records_file" >/dev/null 2>&1; then
    jq -rs '
      sort_by(.issue)
      | .[] | select(has("cost") or has("tokens"))
      | "- #\(.issue): cost=\(.cost // "n/a"), tokens=\(.tokens // "n/a")"
    ' "$records_file"
  else
    echo "- Not recorded in any outcome record yet (reserved for future telemetry; not estimated here)."
  fi
}

self_test() {
  local tmp dir cand_dir out
  tmp=$(mktemp -d)
  trap 'rm -rf "$tmp"' RETURN
  dir="$tmp/outcomes"
  cand_dir="$tmp/candidates"
  mkdir -p "$dir" "$cand_dir"

  jq -n '{
    schema: "agent-outcome/v1", id: "2026-06-01T00:05:00Z-issue-101-success",
    issue: 101, status: "success", exit_code: 0,
    started_at: "2026-06-01T00:00:00Z", finished_at: "2026-06-01T00:05:00Z",
    base_branch: "main", repo_dir: "/repo", head_branch: "codex/issue-101-foo",
    head_sha: "aaa111",
    prs: [{number: 301, title: "feat: foo", state: "MERGED", headRefName: "codex/issue-101-foo", url: "https://example.invalid/pr/301"}],
    learning_candidates: [".agents/learning/candidates/2026-06-01-foo.yml"],
    git_dirty: [], blocker: ""
  }' >"$dir/2026-06-01T00:05:00Z-issue-101-success.json"

  jq -n '{
    schema: "agent-outcome/v1", id: "2026-06-03T00:10:00Z-issue-102-failure",
    issue: 102, status: "failure", exit_code: 1,
    started_at: "2026-06-03T00:00:00Z", finished_at: "2026-06-03T00:10:00Z",
    base_branch: "main", repo_dir: "/repo", head_branch: "codex/issue-102-bar",
    head_sha: "bbb222",
    prs: [{number: 302, title: "feat: bar", state: "OPEN", headRefName: "codex/issue-102-bar", url: "https://example.invalid/pr/302"}],
    learning_candidates: [], git_dirty: ["M flake.nix"], blocker: "build failed: nix flake check"
  }' >"$dir/2026-06-03T00:10:00Z-issue-102-failure.json"

  jq -n '{
    schema: "agent-outcome/v1", id: "2026-06-04T00:01:00Z-issue-103-blocked",
    issue: 103, status: "blocked", exit_code: 1,
    started_at: "2026-06-04T00:00:00Z", finished_at: "2026-06-04T00:01:00Z",
    base_branch: "main", repo_dir: "/repo", head_branch: "main",
    head_sha: "ccc333",
    prs: [], learning_candidates: [], git_dirty: [],
    blocker: "agent-dispatch: pre-dispatch agent-issue-readiness check failed; issue not dispatched"
  }' >"$dir/2026-06-04T00:01:00Z-issue-103-blocked.json"

  # Reviewer approved, but the PR was closed unmerged: an
  # approve-but-CI/merge-failed miscalibration.
  jq -n '{
    schema: "agent-outcome/v1", id: "2026-06-05T00:10:00Z-issue-105-success",
    issue: 105, status: "success", exit_code: 0,
    started_at: "2026-06-05T00:00:00Z", finished_at: "2026-06-05T00:10:00Z",
    base_branch: "main", repo_dir: "/repo", head_branch: "codex/issue-105-baz",
    head_sha: "eee555",
    prs: [{number: 305, title: "feat: baz", state: "CLOSED", headRefName: "codex/issue-105-baz", url: "https://example.invalid/pr/305", mergeStateStatus: "DIRTY"}],
    learning_candidates: [], git_dirty: [], blocker: "",
    review: {schema: "agent-reviewer-evidence/v1", issue: 105, pr: 305, result: "approved"}
  }' >"$dir/2026-06-05T00:10:00Z-issue-105-success.json"

  # Reviewer requested changes, but the PR merged anyway: the opposite
  # miscalibration.
  jq -n '{
    schema: "agent-outcome/v1", id: "2026-06-06T00:10:00Z-issue-106-success",
    issue: 106, status: "success", exit_code: 0,
    started_at: "2026-06-06T00:00:00Z", finished_at: "2026-06-06T00:10:00Z",
    base_branch: "main", repo_dir: "/repo", head_branch: "codex/issue-106-qux",
    head_sha: "fff666",
    prs: [{number: 306, title: "feat: qux", state: "MERGED", headRefName: "codex/issue-106-qux", url: "https://example.invalid/pr/306", mergeStateStatus: "CLEAN"}],
    learning_candidates: [], git_dirty: [], blocker: "",
    review: {schema: "agent-reviewer-evidence/v1", issue: 106, pr: 306, result: "changes_requested"}
  }' >"$dir/2026-06-06T00:10:00Z-issue-106-success.json"

  # Out-of-window record (before --since): must be excluded when filtered.
  jq -n '{
    schema: "agent-outcome/v1", id: "2026-05-01T00:05:00Z-issue-50-success",
    issue: 50, status: "success", exit_code: 0,
    started_at: "2026-05-01T00:00:00Z", finished_at: "2026-05-01T00:05:00Z",
    base_branch: "main", repo_dir: "/repo", head_branch: "codex/issue-50-old",
    head_sha: "ddd444",
    prs: [{number: 200, title: "old pr", state: "MERGED", headRefName: "codex/issue-50-old", url: "https://example.invalid/pr/200"}],
    learning_candidates: [], git_dirty: [], blocker: ""
  }' >"$dir/2026-05-01T00:05:00Z-issue-50-success.json"

  printf 'malformed\n' >"$dir/2026-06-05T00:00:00Z-issue-104-failure.json"

  cat >"$cand_dir/2026-06-01-foo.yml" <<'EOF'
schema: learning-candidate/v1
id: recurring-one
status: open
dedupe_key: repeated:thing
EOF
  cat >"$cand_dir/2026-06-02-bar.yml" <<'EOF'
schema: learning-candidate/v1
id: recurring-two
status: open
dedupe_key: repeated:thing
EOF
  cat >"$cand_dir/2026-06-03-single.yml" <<'EOF'
schema: learning-candidate/v1
id: single-one
status: open
dedupe_key: single:thing
EOF

  local records="$tmp/records.ndjson"

  # Unfiltered: all 6 valid records included, malformed one skipped.
  read_records "$dir" "" >"$records"
  [[ $(wc -l <"$records" | tr -d ' ') -eq 6 ]] || die "self-test: expected 6 valid records (got $(wc -l <"$records"))"

  out=$(render_digest "$records" "$cand_dir" "")
  [[ $out == *"#301 MERGED"* ]] || die "self-test: expected merged PR #301 in digest"
  [[ $out == *"#302 OPEN"* ]] || die "self-test: expected open PR #302 in digest"
  [[ $out == *"#103: agent-dispatch: pre-dispatch"* ]] || die "self-test: expected blocked issue #103 in digest"
  [[ $out == *"#102 (exit 1): build failed: nix flake check"* ]] || die "self-test: expected failed validation #102 in digest"
  [[ $out == *".agents/learning/candidates/2026-06-01-foo.yml (issue(s): #101)"* ]] ||
    die "self-test: expected learning candidate from issue #101 in digest"
  [[ $out == *"2026-06-01-foo.yml"* ]] || die "self-test: expected currently-open candidate listed"
  [[ $out == *"captured 2 times: repeated:thing"* ]] ||
    die "self-test: expected recurring open candidate ranking in digest"
  [[ $out != *"captured 1 times: single:thing"* ]] ||
    die "self-test: singleton dedupe keys should not appear in recurring ranking"
  [[ $out == *"| #101 | success | 300s |"* ]] || die "self-test: expected 300s duration for issue #101 (got: $out)"
  [[ $out == *"PR #302 is OPEN and awaiting review/merge"* ]] || die "self-test: expected open PR in human-decisions section"
  [[ $out == *"Issue #103 is blocked"* ]] || die "self-test: expected blocked issue in human-decisions section"
  [[ $out == *"Issue #102 run failed and needs investigation"* ]] || die "self-test: expected failed issue in human-decisions section"
  [[ $out == *"Not recorded in any outcome record yet"* ]] || die "self-test: expected reserved cost/token note"
  [[ $out != *"#200"* ]] && die "self-test: expected unfiltered digest to include out-of-range PR #200" || true
  [[ $out == *"#105: PR #305 approved by reviewer but state=CLOSED, mergeStateStatus=DIRTY"* ]] ||
    die "self-test: expected approve-but-not-clean calibration entry for issue #105 (got: $out)"
  [[ $out == *"#106: PR #306 merged despite reviewer result=changes_requested"* ]] ||
    die "self-test: expected changes-requested-but-merged calibration entry for issue #106 (got: $out)"

  # --since excludes the older record (issue #50 / PR #200).
  read_records "$dir" "2026-06-01T00:00:00Z" >"$records"
  [[ $(wc -l <"$records" | tr -d ' ') -eq 5 ]] || die "self-test: expected 5 records with --since filter (got $(wc -l <"$records"))"
  out=$(render_digest "$records" "$cand_dir" "2026-06-01T00:00:00Z")
  [[ $out != *"#200"* ]] || die "self-test: expected --since to exclude PR #200 (issue #50)"
  [[ $out == *"#301 MERGED"* ]] || die "self-test: expected --since to keep PR #301 (issue #101)"

  printf 'agent-weekly-digest self-test passed\n'
}

main() {
  local dir="${AGENT_OUTCOME_DIR:-.agents/state/outcomes}"
  local since=""
  local candidates_dir=".agents/learning/candidates"

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --dir)
      dir="${2:?--dir needs a value}"
      shift 2
      ;;
    --since)
      since="${2:?--since needs a value}"
      shift 2
      ;;
    --candidates-dir)
      candidates_dir="${2:?--candidates-dir needs a value}"
      shift 2
      ;;
    --self-test)
      self_test
      exit 0
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      die "unknown argument: $1"
      ;;
    esac
  done

  command -v jq >/dev/null 2>&1 || die "jq not found"

  local records
  records=$(mktemp)
  trap 'rm -f "$records"' EXIT
  read_records "$dir" "$since" >"$records"
  render_digest "$records" "$candidates_dir" "$since"
}

main "$@"
