{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/FilipNowakowicz/nixos-config/.agents/schemas/reviewer-evidence.schema.json",
  "title": "Agent reviewer evidence",
  "type": "object",
  "required": [
    "schema",
    "issue",
    "pr",
    "result",
    "acceptance_criteria",
    "validation_commands",
    "residual_risk"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "agent-reviewer-evidence/v1"
    },
    "issue": {
      "type": "integer",
      "minimum": 1
    },
    "pr": {
      "type": "integer",
      "minimum": 1
    },
    "result": {
      "enum": ["approved", "changes_requested", "blocked"]
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["criterion", "evidence"],
        "additionalProperties": false,
        "properties": {
          "criterion": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "validation_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["command", "result"],
        "additionalProperties": false,
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "enum": ["passed", "failed", "skipped"]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "residual_risk": {
      "type": "string",
      "minLength": 1
    }
  }
}
